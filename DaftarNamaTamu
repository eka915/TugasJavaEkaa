package com.mycompany.ekabelajarjava;
 import java.util.Scanner;
/**
 *
 * @author Hype GLK
 */
public class DaftarNamaTamu {
    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);

        // 1. Meminta input jumlah tamu
        System.out.print("Masukkan jumlah tamu: ");
        int jumlahTamu = scan.nextInt();
        scan.nextLine(); // Membersihkan buffer newline setelah nextInt()

        // Inisialisasi array untuk menyimpan nama
        String[] daftarTamu = new String[jumlahTamu];

        // 2. User menginput nama tamu satu per satu
        for (int i = 0; i < jumlahTamu; i++) {
            System.out.print("Masukkan nama tamu ke-" + (i + 1) + ": ");
            daftarTamu[i] = scan.nextLine();
        }

        System.out.println("\n--- Daftar Nama Tamu ---");

        // 3. Menampilkan semua nama tamu dengan format tertentu
        // 4. Menghitung banyak tamu yang namanya diawali huruf 'A'
        int jumlahHurufA = 0;

        for (int i = 0; i < daftarTamu.length; i++) {
            System.out.println("Tamu " + (i + 1) + ": " + daftarTamu[i]);

            // Cek apakah nama diawali dengan 'A' (Case Sensitive)
            if (daftarTamu[i].startsWith("A")) {
                jumlahHurufA++;
            }
        }

        System.out.println("------------------------");
        System.out.println("Banyak tamu dengan nama diawali huruf 'A': " + jumlahHurufA);

        scan.close();
}
}
